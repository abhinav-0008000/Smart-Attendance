{
  "id": "attendance-hub-lendi",
  "name": "Smart Attendance Portal",
  "short_name": "Attendance Hub",
  "description": "The Official Biometric Attendance & Geofencing System for Lendi Institute of Engineering & Technology.",
  "lang": "en-US",
  "dir": "ltr",
  "start_url": "/auth.html",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#001a33",
  "theme_color": "#003366",
  "categories": ["education", "productivity", "utilities"],
  "iarc_rating_id": "e58c-4f7f-8561-123456789012",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.lendi_institute.attendance",
      "id": "com.lendi_institute.attendance"
    }
  ],
  "icons": [
    {
      "src": "college-logo.png",
      "sizes": "192x192 512x512 any",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "college-logo.png",
      "sizes": "192x192 512x512 any",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "college-logo.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "label": "Login Screen",
      "form_factor": "narrow"
    },
    {
      "src": "college-logo.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "label": "Admin Dashboard",
      "form_factor": "wide"
    }
  ],
  "shortcuts": [
    {
      "name": "Student Login",
      "url": "/auth.html",
      "description": "Direct student portal access",
      "icons": [
        {
          "src": "college-logo.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/auth.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/auth.html",
      "accept": {
        "text/plain": [".txt"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+attendance",
      "url": "/auth.html?url=%s"
    }
  ],
  "widgets": [
    {
      "name": "Attendance Status",
      "short_name": "Status",
      "description": "View live attendance stats on your dashboard.",
      "tag": "attendance_widget",
      "ms_ac_template": "widget.json",
      "icons": [
        {
          "src": "college-logo.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ],
      "screenshots": [
        {
          "src": "college-logo.png",
          "sizes": "512x512",
          "type": "image/png",
          "label": "Live Sync View"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "display_override": ["window-controls-overlay", "tabbed", "standalone"],
  "note_taking": {
    "new_note_url": "/auth.html"
  },
  "scope_extensions": [
    {
      "origin": "https://attendance-portal-lendi.netlify.app"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  }
}
